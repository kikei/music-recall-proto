# OpenAI API キー (必須)
OPENAI_API_KEY=sk-...

# 対話・圧縮・作品調査に使うモデル (web 検索対応)
OPENAI_MODEL=gpt-5.5

# 想起の選別・理由生成 (rerank) に使う高速モデル
RANK_MODEL=gpt-4o-mini

# 想起の意味検索に使う埋め込みモデル
OPENAI_EMBED_MODEL=text-embedding-3-small

# バックエンドのポート
PORT=8787

# 視聴プレイヤー (任意)。Spotify を優先し、無ければ YouTube を使う。
# Spotify: https://developer.spotify.com でアプリ登録 → Client Credentials
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# YouTube Data API v3 のキー (Google Cloud)
YOUTUBE_API_KEY=
