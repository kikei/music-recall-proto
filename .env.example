# OpenAI API key (required)
OPENAI_API_KEY=sk-...

# Model for dialogue, compression, and research (web search capable)
OPENAI_MODEL=gpt-5.5

# Fast model for reranking and reason generation in recall
RANK_MODEL=gpt-4o-mini

# Embedding model for semantic search in recall
OPENAI_EMBED_MODEL=text-embedding-3-small

# SQLite file path
DB_PATH=data/music-recall.sqlite

# Backend port
PORT=8787

# Viewing player (optional). Spotify is preferred; YouTube is used otherwise.
# Spotify: register an app at https://developer.spotify.com -> Client
# Credentials
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# YouTube Data API v3 key (Google Cloud)
YOUTUBE_API_KEY=
